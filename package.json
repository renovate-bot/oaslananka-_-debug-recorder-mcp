{
  "name": "debug-recorder-mcp",
  "version": "1.1.0",
  "description": "MCP server for recording debug sessions — query your debugging history with natural language",
  "type": "module",
  "main": "dist/mcp.js",
  "exports": {
    ".": "./dist/mcp.js",
    "./store": "./dist/store.js",
    "./db": "./dist/db.js",
    "./types": "./dist/types.js"
  },
  "types": "dist/mcp.d.ts",
  "bin": {
    "debug-recorder-mcp": "dist/mcp.js"
  },
  "mcpName": "io.github.oaslananka/debug-recorder-mcp",
  "files": [
    "dist",
    "mcp.json",
    "server.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "SUPPORT.md",
    "CODE_OF_CONDUCT.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "ts-node --esm src/mcp.ts",
    "start": "node dist/mcp.js",
    "start:http": "node dist/server-http.js",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck && eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "node scripts/run-jest.mjs --testPathIgnorePatterns=e2e --testPathIgnorePatterns=fuzz",
    "test:coverage": "node scripts/run-jest.mjs --coverage --testPathIgnorePatterns=e2e --testPathIgnorePatterns=fuzz",
    "test:e2e": "node scripts/run-jest.mjs --suite=e2e --testPathPatterns=e2e",
    "test:fuzz": "node scripts/run-jest.mjs --suite=fuzz --testPathPatterns=fuzz --runInBand",
    "docs:api": "typedoc --options typedoc.json",
    "audit": "npm audit --audit-level=moderate",
    "check:install-scripts": "node scripts/check-install-scripts.mjs",
    "check:dead-code": "knip --config knip.json --reporter compact",
    "check:package-size": "node scripts/check-package-size.mjs",
    "check:version": "node scripts/check-version-sync.mjs",
    "check:mcp": "node scripts/validate-mcp-metadata.mjs",
    "check:mcp-registry": "node scripts/verify-mcp-registry-release.mjs",
    "check:mcp-registry:published": "node scripts/verify-mcp-registry-release.mjs --require-npm",
    "check:security-policy": "node scripts/validate-security-policy.mjs",
    "ci:local": "npm run format:check && npm run lint && npm run check:dead-code && npm run test:coverage && npm run test:fuzz && npm run build && npm run test:e2e && npm run audit && npm run check:install-scripts && npm pack --dry-run && npm run check:package-size && npm run check:version && npm run check:mcp && npm run check:security-policy",
    "prepare": "npm run build",
    "prepublishOnly": "npm run lint && npm run format:check && npm run check:dead-code && npm run test:coverage && npm run test:fuzz && npm run build && npm run test:e2e && npm run audit && npm run check:install-scripts && npm run check:package-size && npm run check:version && npm run check:mcp && npm run check:security-policy",
    "version": "node scripts/sync-version.mjs && git add package.json package-lock.json mcp.json server.json"
  },
  "engines": {
    "node": "^22.0.0 || ^24.0.0",
    "npm": ">=10.0.0"
  },
  "keywords": [
    "mcp",
    "debug",
    "developer-tools",
    "sqlite",
    "ai",
    "mcp-server",
    "mcp-client"
  ],
  "author": "Osman Aslan <oaslananka@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oaslananka/debug-recorder-mcp.git"
  },
  "homepage": "https://github.com/oaslananka/debug-recorder-mcp#readme",
  "bugs": {
    "url": "https://github.com/oaslananka/debug-recorder-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "better-sqlite3": "12.8.0",
    "fuse.js": "7.3.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@jest/globals": "30.4.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/node": "22.19.17",
    "@typescript-eslint/eslint-plugin": "8.58.1",
    "@typescript-eslint/parser": "8.58.1",
    "eslint": "9.39.4",
    "fast-check": "4.8.0",
    "globals": "17.4.0",
    "jest": "^30.4.2",
    "jest-junit": "^17.0.0",
    "knip": "6.14.2",
    "prettier": "^3.3.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typedoc": "0.28.19",
    "typedoc-plugin-markdown": "4.12.0",
    "typescript": "5.9.3"
  },
  "overrides": {
    "babel-plugin-istanbul": "8.0.0",
    "express-rate-limit": "8.5.1",
    "fast-uri": "3.1.2",
    "glob": "13.0.6",
    "hono": "4.12.27",
    "ip-address": "10.2.0",
    "test-exclude": "8.0.0",
    "@babel/core": "7.29.7",
    "js-yaml": "4.2.0",
    "markdown-it": "14.2.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "allowScripts": {
    "better-sqlite3@12.8.0": true,
    "unrs-resolver@1.12.2": true
  }
}
